# Slack credentials (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token   # socket mode — needs connections:write scope

# Optional: channel to receive HR alerts (budget escalations + equity flags)
HR_ALERTS_CHANNEL=#hr-comp-alerts

# Web dashboard public URL (use ngrok for local dev, or your deployed URL)
DASHBOARD_URL=http://localhost:3001
DASHBOARD_PORT=3001

# MCP server
MCP_SERVER_URL=http://localhost:8080/mcp
MCP_PORT=8080

# Database (defaults to SQLite in project root)
DATABASE_URL=sqlite:///comp_data.db
